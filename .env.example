# ── LLM provider ──────────────────────────────────────────────────────────────
# "openai" (default) or "ollama"
# LLM_PROVIDER=openai

# ── OpenAI (used when LLM_PROVIDER=openai or unset) ───────────────────────────
# OPENAI_API_KEY=sk-...

# ── Ollama (used when LLM_PROVIDER=ollama) ────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:e2b
# (OLLAMA_CHILD_MODEL is accepted as an alias for OLLAMA_MODEL)

# ── Storage ───────────────────────────────────────────────────────────────────
# Where to store the knowledge base on disk (default: ~/.code-dna)
# KNOWLEDGE_BASE_DIR=~/.code-dna

# ── OpenAI model overrides (only relevant when LLM_PROVIDER=openai) ───────────
# Default model for all stages
# KNOWLEDGE_MODEL=gpt-4o-mini

# Override models per stage (falls back to KNOWLEDGE_MODEL when unset)
# KNOWLEDGE_INDEX_MODEL=gpt-4o-mini
# KNOWLEDGE_QUERY_MODEL=gpt-4o-mini
# KNOWLEDGE_REASONING_MODEL=o3-mini

# ── Scan behaviour ────────────────────────────────────────────────────────────
# Scan mode: "smart" (skip deps/generated) or "deep" (index everything)
# KNOWLEDGE_SCAN_MODE=smart

# Max tokens for the master context document
# KNOWLEDGE_TARGET_TOKENS=80000

# Parallel summarisation workers
# KNOWLEDGE_CONCURRENCY=5
